# ---- Engine + data job secrets (set as GitHub Actions secrets / Render env vars) ----

# Anthropic API key for the prediction engine
ANTHROPIC_API_KEY=

# API-Football key (FREE TIER — 100 req/day cap. Do NOT upgrade without asking Patrick.)
FOOTBALL_API_KEY=

# Model policy (the hedge). Flip these without a redeploy.
PREDICTION_MODEL_GROUP=claude-sonnet-4-6
PREDICTION_MODEL_KO=claude-opus-4-8

# Optional: Render deploy hook URL (POSTed after a successful data commit to force redeploy)
RENDER_DEPLOY_HOOK=

# Optional overrides
# DATA_DIR=./data
# DRY_RUN=1            # when set, engine never calls Anthropic — uses a stub prediction
